{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the streaming platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "watchHistory": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Array of movie IDs watched by the user."
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and their watch history."
    }
  }
}
